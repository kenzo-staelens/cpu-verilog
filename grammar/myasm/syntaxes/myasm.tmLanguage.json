{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Veri CPU Assembly",
  "scopeName": "source.myasm",
  "patterns": [
    { "include": "#parameters" },
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#registers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.myasm",
          "match": ";.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name":"keyword.opcode.alu.myasm",
          "match": "(?i)^\\s*(ssnop|nand|or|and|nor|add|sub|xor|lsl|lsr|cmp|mul)\\b"
        },
        {
          "name":"keyword.opcode.io.myasm",
          "match": "(?i)^\\s*(nop|clk|in|out|sts|dev)\\b"
        },
        {
          "name":"keyword.opcode.mem.myasm",
          "match": "(?i)^\\s*(str|ld|str\\.p|ld\\.p)\\b"
        },
        {
          "match": "(?i)^\\s*(jmp|jeq|jne|jlt(?:\\.s)?|jge(?:\\.s)?|jle(?:\\.s)?|jgt(?:\\.s)?)\\s+([a-z_][a-z0-9_]*|[0-9]+[bf])?\\b",
          "captures": {
            "1": {"name": "keyword.opcode.jmp.myasm"},
            "2": {"name": "parameters.word.label"}
          }
        },
        {
          "name":"keyword.opcode.pseudo.myasm",
          "match": "(?i)^\\s*(hlt|mov)\\b"
        },
        {
          "name": "keyword.directive.myasm",
          "match": "\\.(label|macro|endmacro|org|align|raw|text)\\b"
        },
        {
          "name": "keyword.directive.section.myasm",
          "match": "\\b(section)\\b(?:\\s+\\.(data|text|bss|vector))?",
          "captures": {
            "1": { "name": "keyword.directive.myasm" },
            "2": { "name": "parameters.section.label.myasm" }
          }
        },
        {
          "match": "(%)(\\w+)\\b",
          "captures": {
            "1": { "name": "keyword.macro.myasm" },
            "2": { "name": "parameters.macro.label.myasm" }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.hex.myasm",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.myasm",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.octal.myasm",
          "match": "\\b0o[0-7]+\\b"
        },
        {
          "name": "constant.numeric.decimal.myasm",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "string.quoted.single",
          "match": "'.'"
        },
        {
          "name": "string.quoted.double",
          "match": "\".*\""
        }
      ]
    },
    "registers": {
      "patterns": [
        {
          "name": "constant.namedregister.myasm",
          "match": "\\b(zr|flags|sp)\\b"
        },
        {
          "name": "constant.register.myasm",
          "match": "\\br([1-9]|1[0-3])\\b"
        }
      ]
    },
    "parameters": {
      "patterns":[
        {
          "match": "(\\.label)\\s+(\\w+)",
          "captures": {
            "1": { "name": "keyword.directive.myasm" },
            "2": { "name": "parameters.word.label" }
          }
        },
        {
          "name": "meta.macro.block",
          "begin": "(\\.macro)\\s+(\\w+)",
          "beginCaptures": {
            "1": { "name": "keyword.directive.myasm" },
            "2": { "name": "parameters.macro.label.myasm" }
          },
          "end": "\\.endmacro",
          "endCaptures": {
            "0": { "name": "keyword.directive.myasm" }
          },
          "patterns": [
            { "include": "#parameters" },
            { "include": "#comments" },
            { "include": "#keywords" },
            { "include": "#constants" },
            { "include": "#registers" }
          ]
        }
        
  
      ]
    }
  }
}