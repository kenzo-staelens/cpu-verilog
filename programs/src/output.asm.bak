; uart sts[0] = clear to send
; uart sts[0] = waiting

; raw output 'AB' to uart terminal, then exit
.macro waitloop
.label 1
sts r1
and r1, r1, 0x01
cmp r1, zr
jeq 1b
.endmacro
section .text
mov r2, 0b00110011 ;'A'
mov r3, 'B'
%waitloop
out r2
%waitloop
out r2
%waitloop
out r2
; %waitloop
; out r3
hlt
